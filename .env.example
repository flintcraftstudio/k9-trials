PORT=8080

# Postmark (contact form emails)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=noreply@example.com
POSTMARK_TO=hello@example.com

# Tracking (omit to disable)
GTAG_ID=
PIXEL_ID=

# Cloudflare Turnstile (omit to disable)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Database
DB_PATH=./data/app.db

# Session
SESSION_SECRET=changeme

# Demo mode — set to 1 to expose the admin "Reset demo data" button, which
# wipes and reseeds the demo world. Leave unset in real deployments.
DEMO_MODE=
