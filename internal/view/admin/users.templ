// UsersPage manages user accounts and roles.
templ UsersPage() {
	@shell("Users", "Manage accounts and roles.", "users", "", usersBody())
}

templ usersBody() {
	@components.StubPage(
		"Admin · Users",
		"All accounts.",
		"List users; change role (admin / judge / competitor); link to competitor identity.",
	)
}
